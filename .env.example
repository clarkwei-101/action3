# ============================================================
# Action 3 — Big-AGI Custom AGI Extension
# Vercel 环境变量模板
# 复制此文件为 .env.local 或在 Vercel Dashboard 中配置以下变量
# ============================================================

# ============================================================
# Database
# Vercel Postgres (推荐) / SQLite (本地开发)
# ============================================================
# For Vercel Postgres:
# POSTGRES_PRISMA_URL=postgresql://...
# POSTGRES_URL_NON_POOLING=postgresql://...

# For SQLite (本地开发用):
DATABASE_URL=file:./action3.db

# ============================================================
# LLM API Keys
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ============================================================
# Optional Services
# ============================================================
# GOOGLE_CLOUD_API_KEY=
# GOOGLE_CSE_ID=

# ============================================================
# Web Push Notifications (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# ELEVENLABS_API_KEY=

# ============================================================
# Authentication
# ============================================================
# HTTP_BASIC_AUTH_USERNAME=
# HTTP_BASIC_AUTH_PASSWORD=

# ============================================================
# Playwright Browser Service
# ============================================================
# PLAYWRIGHT_WS_ENDPOINT=

# ============================================================
# Build Configuration
# ============================================================
# NEXT_PUBLIC_BUILD_HASH (auto-set by Vercel)
# VERCEL_GIT_COMMIT_SHA (auto-set by Vercel)
